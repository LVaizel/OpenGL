#version 330 core // OpenGL version 3.3 (minimum requirement)

in vec2 retTexCoords;

out vec4 fragColor; // Output color

uniform sampler2D screenTexture;
void main() {
	vec3 color = texture(screenTexture, retTexCoords).rgb;

	//Grayscale effect
	color = vec3(dot(color, vec3(0.2126, 0.7152, 0.0722))); // corrected typo
	
	//Inverted effect
	//color = 1 - color;

	fragColor = vec4(color, 1.0);
}