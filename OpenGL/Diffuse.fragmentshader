#version 330 core // OpenGL version 3.3 (minimum requirement)

in vec3 retNormal; // Input from vertex shader
in vec2 retTexCoords;

out vec4 fragColor; // Output color

uniform sampler2D sampler1;
uniform sampler2D sampler2;

void main() {
	fragColor = mix(texture2D(sampler1, retTexCoords), texture2D(sampler2, retTexCoords), 0.3) * vec4(retNormal, 1.0f);
}