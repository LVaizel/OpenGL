#version 330 core // OpenGL version 3.3 (minimum requirement)

in vec2 retTexCoords;

out vec4 fragColor; // Output color

struct Material {
    sampler2D diffuseTexture;
};

uniform Material material;
uniform vec3 textColor;

void main() {
    float sampledAlpha = texture(material.diffuseTexture, retTexCoords).r;
    vec4 sampledColor = vec4(1.0, 1.0, 1.0, sampledAlpha);
    fragColor = sampledColor * vec4(textColor, 1.0);
}